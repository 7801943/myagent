FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash coreutils curl && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
COPY pyproject.toml .
RUN pip install --no-cache-dir -e . 2>/dev/null || true

CMD ["python", "-m", "myagent.tools.runner", "--tcp", "--port", "9876"]
