# MyAgent 配置文件
# API Key 等敏感信息请自行填入

agent:
  # System Prompt
  system_prompt: "你是一个智能助手，可以帮助用户完成各种任务。"
  system_prompt_file: "config/prompt.txt"

  # 最大 ReAct 迭代次数
  max_iterations: 50

  # LLM 流式生成超时（秒）
  llm_timeout: 120.0

  # Provider 配置（支持多路冗余）
  providers:
    - name: "openai-primary"
      type: "openai"
      model: "glm-5.1"
      api_key: "4d1d17ae5953451e872f0efcf9c4ffe2.WILVHXpssYeAPLQD"                        # TODO: 填入你的 API Key
      api_base: "https://open.bigmodel.cn/api/coding/paas/v4"
      priority: 1

    - name: "openai-backup"
      type: "openai"
      model: "gpt-4o-mini"
      api_key: "${OPENAI_API_KEY}"       # 从环境变量读取
      priority: 2

    # - name: "anthropic"
    #   type: "anthropic"
    #   model: "claude-sonnet-4-20250514"
    #   api_key: "${ANTHROPIC_API_KEY}"

  # ── 故障转移配置 ──
  failover:
    strategy: "priority"                           # priority | round_robin | latency
    circuit_breaker_failure_threshold: 3
    circuit_breaker_recovery_seconds: 60

  # 上下文管理
  context:
    max_tokens_budget: 200000
    tool_result_max_chars: 200000
    recent_turns: 20

  # 工具执行
  tools:
    default_timeout: 30.0
    batch_timeout: 60.0                            # 工具批量执行超时（秒）

  # ── 审计日志 ──
  audit:
    enabled: true
    level: "standard"                              # standard | minimal | verbose
    environment: "dev"
    queue_size: 2000
    jsonl_log_dir: "./audit_logs"
    jsonl_retention_days: 90

  # ── 工具热加载 ──
  hot_reload:
    enabled: false
    watch_dir: "myagent/tools/tools_store"
    poll_interval: 60.0
    safe_mode: false

  # ── 安全系统 ──
  safety:
    enabled: true
    rules_path: "./config/safety_rules.yaml"
    default_action: "allow"          # allow | deny

  # ── 沙盒配置 ──
  sandbox:
    backend: "subprocess"            # subprocess | docker (预留)
    max_cpu_seconds: 30
    max_memory_mb: 512
    max_output_bytes: 102400         # 100KB
    timeout_seconds: 60.0

  # ── 人在回路 ──
  hitl:
    enabled: true                    # 是否启用 HITL 审批
    timeout: 120                     # 审批超时（秒）
    approval_timeout: 300.0          # 人工审批等待超时（秒）

  # ── 密钥管理 ──
  secrets:
    env_prefix: "MYAGENT_SECRET_"
    sensitive_fields:
      - "password"
      - "api_key"
      - "token"
      - "secret"
      - "access_key"
      - "secret_key"

  # 可观测性（遗留配置，审计日志已迁移到 audit 段）
  observability:
    audit_backend: "jsonl"    # jsonl | sqlite
    audit_path: "./logs/audit.jsonl"
    log_level: "INFO"

  # 状态持久化
  state:
    backend: "jsonl"          # jsonl | sqlite
    path: "./state/sessions.jsonl"
