# MyAgent 配置文件
# API Key 等敏感信息请自行填入

agent:
  # 用户根目录（CLI 工具将不能越过此目录进行操作）
  root_dir: ""

  # System Prompt（降级用，当 prompt_template.yaml 缺失时使用）
  system_prompt: "你是一个智能助手，可以帮助用户完成各种任务。"
  system_prompt_file: "config/prompt.txt"

  # 结构化系统提示词模板（SSPT）— 新增
  prompt_template_path: "config/prompt_template.yaml"

  # 上下文窗口大小（可配置，默认 200000）
  context_window_size: 200000

  # 最大 ReAct 迭代次数
  max_iterations: 50

  # LLM 流式生成超时（秒）
  llm_timeout: 120.0

  # Provider 配置（支持多路冗余）
  providers:
    - name: "openai-primary"
      type: "openai"
      model: "glm-5.1"
      api_key: ""                        # TODO: 填入你的 API Key
      api_base: "https://open.bigmodel.cn/api/coding/paas/v4"
      priority: 1
      thinking:
        supported: true
        default_enabled: false
        enabled_extra_body:
          thinking:
            type: "enabled"
        disabled_extra_body:
          thinking:
            type: "disabled"

    - name: "openai-backup"
      type: "openai"
      model: "gpt-4o-mini"
      api_key: "${OPENAI_API_KEY}"       # 从环境变量读取
      priority: 2

    # - name: "anthropic"
    #   type: "anthropic"
    #   model: "claude-sonnet-4-20250514"
    #   api_key: "${ANTHROPIC_API_KEY}"

  # ── 故障转移配置 ──
  failover:
    strategy: "priority"                           # priority | round_robin | latency
    circuit_breaker_failure_threshold: 3
    circuit_breaker_recovery_seconds: 60

  # 上下文管理
  context:
    max_tokens_budget: 200000
    tool_result_max_chars: 200000
    recent_turns: 20

  # 工具执行
  tools:
    default_timeout: 30.0
    batch_timeout: 60.0                            # 工具批量执行超时（秒）

  # ── Skills 系统 ──
  skills:
    enabled: true
    # 公共 Skill 目录；每个用户再通过 data/users.json 的 visible_skills 控制可见性
    common_dir: "prompts/skills/common"
    # 启用的 skill 名称列表；留空则启用 common_dir 下的所有可见 skill
    active: []
      # - "office-automation"
      # - "web-search"

  # ── 审计日志 ──
  audit:
    enabled: true
    level: "standard"                              # standard | minimal | verbose
    environment: "dev"
    queue_size: 2000
    jsonl_log_dir: "./audit_logs"
    jsonl_retention_days: 90

  # ── 工具热加载 ──
  hot_reload:
    enabled: false
    watch_dir: "myagent/tools/tools_store"
    poll_interval: 60.0
    safe_mode: false

  # ── 安全系统 ──
  safety:
    enabled: true
    rules_path: "./config/safety_rules.yaml"
    default_action: "allow"          # allow | deny

  # ── 沙盒配置 ──
  sandbox:
    backend: "subprocess"            # subprocess | docker (预留)
    max_cpu_seconds: 30
    max_memory_mb: 512
    max_output_bytes: 102400         # 100KB
    timeout_seconds: 60.0

  # ── 人在回路 ──
  hitl:
    enabled: true                    # 是否启用 HITL 审批
    timeout: 120                     # 审批超时（秒）
    approval_timeout: 300.0          # 人工审批等待超时（秒）

  # ── 密钥管理 ──
  secrets:
    env_prefix: "MYAGENT_SECRET_"
    sensitive_fields:
      - "password"
      - "api_key"
      - "token"
      - "secret"
      - "access_key"
      - "secret_key"

  # 可观测性（遗留配置，审计日志已迁移到 audit 段）
  observability:
    audit_backend: "jsonl"    # jsonl | sqlite
    audit_path: "./logs/audit.jsonl"
    log_level: "INFO"

  # 状态持久化
  state:
    backend: "jsonl"          # jsonl | sqlite
    path: "./state/sessions.jsonl"

# ── 多用户状态与工作区 ──
multi_user:
  enabled: true

state:
  # 每个用户一个 SQLite 状态库：data/state/users/<username>/myagent_state.db
  per_user_dir: "data/state/users"

workspace:
  # 多用户工作区前端直接显示配置目录名：
  #   <private_dir 的目录名>/... -> 当前用户私有目录
  #   <public_dir 的目录名>/...  -> 所有用户共享目录
  #
  # 例如 zhouxiang 用户 private_dir=/home/zhouxiang/用户文件/zhouxiang，
  # public_dir=/home/zhouxiang/工作文件 时，前端显示：
  #   zhouxiang/...
  #   工作文件/...
  #
  # 用户私有目录默认由 private_dir_template 生成；如需单独覆盖某个用户，
  # 在 data/users.json 中设置该用户的 workspace.private_dir。
  #
  # 示例：
  #   admin    -> workspaces/users/admin
  #   zhouxiang -> workspaces/users/zhouxiang
  #   test     -> workspaces/users/test
  base_dir: "workspaces"
  private_dir_template: "workspaces/users/{username}"
  public_dir: "workspaces/public"
  public_upload_enabled: true
  public_rename_delete_group: "admin"

# ── 认证系统 ──
auth:
  enabled: true                         # 是否启用认证
  users_file: "data/users.json"         # 用户数据文件路径
  token_ttl_seconds: 86400              # Token 有效期（秒），默认 24 小时
  max_ips_per_user: 4                   # 每用户最大同时连接 IP 数
  trusted_proxies: []                   # 信任的反向代理地址列表
  # trusted_proxies:                    # 示例：Nginx 反向代理场景
  #   - "127.0.0.1"
  #   - "::1"

# ── 文档预览/编辑（OnlyOffice）──
documents:
  enabled: false
  onlyoffice_url: "http://localhost:8081"
  myagent_public_url: "http://localhost:8001"
  myagent_internal_url: "http://host.docker.internal:8001"
  access_token_ttl_seconds: 3600
  access_token_secret: "${MYAGENT_DOCUMENT_TOKEN_SECRET}"
  onlyoffice_jwt_secret: "${ONLYOFFICE_JWT_SECRET}"
  onlyoffice_jwt_header: "AuthorizationJwt"
  supported_extensions:
    - ".doc"
    - ".docx"
    - ".odt"
    - ".rtf"
    - ".txt"
    - ".md"
    - ".markdown"
    - ".xls"
    - ".xlsx"
    - ".ods"
    - ".csv"
    - ".ppt"
    - ".pptx"
    - ".odp"
    - ".pdf"
